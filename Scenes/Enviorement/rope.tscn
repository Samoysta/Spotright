[sub_resource type="CSharpScript" id="CSharpScript_fq40r"]
script/source = "using Godot;
using System;

public partial class Rope : Node2D
{
	[Export] public Node2D pointA;
	[Export] public Node2D pointB;

	[Export] public int segmentCount = 25;
	[Export] public float gravity = 1800f;
	[Export] public int iterations = 12;

	[Export] public float waveSpeed = 2f;
	[Export] public float waveStrength = 3f;

	Line2D line;

	Vector2[] positions;
	Vector2[] oldPositions;
	float segmentLength;

	public override void _Ready()
	{
		line = GetNode<Line2D>(\"Line2D\");

		positions = new Vector2[segmentCount];
		oldPositions = new Vector2[segmentCount];

		// başlangıç düz ip
		for (int i = 0; i < segmentCount; i++)
		{
			Vector2 pos = pointA.GlobalPosition.Lerp(pointB.GlobalPosition, (float)i / (segmentCount - 1));
			positions[i] = pos;
			oldPositions[i] = pos;
		}

		segmentLength = pointA.GlobalPosition.DistanceTo(pointB.GlobalPosition) / (segmentCount - 1);

		line.Points = new Vector2[segmentCount];
	}

	public override void _PhysicsProcess(double delta)
	{
		float dt = (float)delta;
		float time = Time.GetTicksMsec() * 0.001f;

		// 🔹 Verlet + sürekli hareket
		for (int i = 1; i < segmentCount - 1; i++)
		{
			Vector2 velocity = positions[i] - oldPositions[i];
			oldPositions[i] = positions[i];

			positions[i] += velocity;

			// gravity
			positions[i] += new Vector2(0, gravity * dt * dt);

			// 🔥 sürekli sallanma (dalga)
			float wave =
				Mathf.Sin(time * waveSpeed + i * 0.5f) +
				Mathf.Cos(time * (waveSpeed * 0.7f) + i * 0.8f);

			float strength = (float)i / segmentCount;

			positions[i] += new Vector2(wave * waveStrength * strength, 0);
		}

		// 🔹 constraint çözümü
		for (int j = 0; j < iterations; j++)
		{
			positions[0] = pointA.GlobalPosition;
			positions[segmentCount - 1] = pointB.GlobalPosition;

			for (int i = 0; i < segmentCount - 1; i++)
			{
				Vector2 diff = positions[i + 1] - positions[i];
				float dist = diff.Length();
				float error = dist - segmentLength;

				Vector2 change = diff.Normalized() * error * 0.5f;

				if (i != 0)
					positions[i] += change;

				if (i + 1 != segmentCount - 1)
					positions[i + 1] -= change;
			}
		}

		// 🔹 çizim
		for (int i = 0; i < segmentCount; i++)
		{
			line.SetPointPosition(i, ToLocal(positions[i]));
		}
	}
}"

